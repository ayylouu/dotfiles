# reload sxhkd:
super + alt + k
	kill $(pidof sxhkd) && sxhkd &

# Programs
super + Return
    	$TERMINAL

super + shift + Return
    	st

super + d
    	dmenu_run

super + shift + w
    	librewolf

super + w
    	brave

ctrl + alt + d
    	discord

super + alt + m
	$TERMINAL -e ncmpcpp

super + e
	$TERMINAL -e lf

super + shift + e
	pcmanfm

ctrl + alt + p
     	$TERMINAL -e pulsemixer

super + Escape
    	$TERMINAL -e htop

super + shift + n
	terminator -e newsboat

super + shift + t
	st -e stig

alt + shift + t
	browser

alt + shift + f
	ferdi

super + shift + s
	steam

super + v
	virtualbox

